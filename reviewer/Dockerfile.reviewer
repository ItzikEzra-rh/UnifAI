# Start with NVIDIA CUDA base image compatible with RHEL9
FROM nvidia/cuda:12.4.0-devel-ubi9

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV HF_TOKEN="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"
ENV GITHUB_TOKEN="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"

# Set working directory
WORKDIR /app

# Install system dependencies
RUN dnf update -y && \
    dnf install -y python3-pip git python3-devel gcc gcc-c++ make cmake kernel-devel wget which numactl \
    && dnf clean all

# Install pip and virtualenv
RUN pip3 install --upgrade pip virtualenv

# Create virtual environment with absolute path
RUN python3 -m virtualenv /app/venv

# Install huggingface_hub before logging in
RUN /bin/bash -c "source /app/venv/bin/activate && \
    pip install --upgrade huggingface_hub"

# Clone the repository using token authentication
RUN git clone https://Nirsisr:${GITHUB_TOKEN}@github.com/Nirsisr/AI-TC-s-Generator.git /app/repo

# Login to Hugging Face
# RUN /bin/bash -c "source /app/venv/bin/activate && \
#     huggingface-cli login --token ${HF_TOKEN}"

# Change to repository directory and install dependencies
WORKDIR /app/repo

# Install dependencies
# RUN /bin/bash -c "source /app/venv/bin/activate && \
#     pip install --upgrade pip && \
#     pip install -r prompt_lab/requirements.txt && \
#     pip install vllm celery"

# Install dependencies
RUN /bin/bash -c "source /app/venv/bin/activate && \
    pip install --upgrade pip && \
    pip install flask-cors websocket-client websockets scapy pymongo uwsgi webargs flask_pymongo pandas celery celery-batches && \
    pip install vllm celery"

# Create a startup script to run the services
RUN echo '#!/bin/bash' > /app/start-service.sh && \
    echo 'source /app/venv/bin/activate' >> /app/start-service.sh && \
    echo 'case "$1" in' >> /app/start-service.sh && \
    echo '  "reviewer")' >> /app/start-service.sh && \
    echo '    celery -A reviewer.celery_app.init worker -c 1 --loglevel=info -Q reviewer_queue -n reviewer' >> /app/start-service.sh && \
    echo '    ;;' >> /app/start-service.sh && \
    echo '  "reviewer_pass_fail")' >> /app/start-service.sh && \
    echo '    celery -A reviewer.celery_app.init worker -c 1 --loglevel=info -Q reviewer_pass_queue,reviewer_fail_queue -n reviewer' >> /app/start-service.sh && \
    echo '    ;;' >> /app/start-service.sh && \
    echo '  *)' >> /app/start-service.sh && \
    echo '    echo "Please specify service: reviewer, or reviewer_pass_fail"' >> /app/start-service.sh && \
    echo '    exit 1' >> /app/start-service.sh && \
    echo '    ;;' >> /app/start-service.sh && \
    echo 'esac' >> /app/start-service.sh && \
    chmod +x /app/start-service.sh

# Set the entrypoint to the startup script
ENTRYPOINT ["/app/start-service.sh"]

# Default command (can be overridden)
CMD ["vllm"]