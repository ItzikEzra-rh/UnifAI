# For more information on configuration, see:
#   * Official English Documentation: http://nginx.org/en/docs/


worker_processes auto;
error_log /var/log/nginx/error.log;
pid /tmp/nginx.pid;

# Load dynamic modules. See /usr/share/doc/nginx/README.dynamic.
include /usr/share/nginx/modules/*.conf;

events {
    worker_connections 1024;
}

http {
    log_format  main  '${DOLLAR}remote_addr - ${DOLLAR}remote_user [${DOLLAR}time_local] "${DOLLAR}request" '
                      '${DOLLAR}status ${DOLLAR}body_bytes_sent "${DOLLAR}http_referer" '
                      '"${DOLLAR}http_user_agent" "${DOLLAR}http_x_forwarded_for"';

    access_log  /var/log/nginx/access.log  main;

    sendfile            on;
    tcp_nopush          on;
    tcp_nodelay         on;
    keepalive_timeout   65;
    types_hash_max_size 4096;

    include             /etc/nginx/mime.types;
    default_type        application/octet-stream;

    # Load modular configuration files from the /etc/nginx/conf.d directory.
    # See http://nginx.org/en/docs/ngx_core_module.html#include
    # for more information.
    include /opt/app-root/etc/nginx.d/*.conf;

    # HTTP Redirection Server Block - currently not in use as this port won't be available to the roue in the first place
    #server {
    #    listen 8080 default_server;
    #    listen [::]:8080 default_server;
    #    server_name your_domain.com; # IMPORTANT: Replace with your actual domain

        # Redirect all HTTP requests to HTTPS on the standard 443 port
        # NOTE: If you must use port 8080 for HTTPS due to a proxy, use $host:8080$request_uri;
        # For a standard redirect:
    #    return 301 https://$host$request_uri; 
    #}

    server {
        listen       ${NGINX_PORT} ssl default_server;
        listen       [::]:${NGINX_PORT} ssl default_server;
        server_name  _;
        
        # SSL Configuration 
        ssl_certificate /etc/nginx/ssl/unifai.crt; # Path to your .pem file
        ssl_certificate_key /etc/nginx/ssl/unifai.key; # Use the same .pem file

        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';
        ssl_prefer_server_ciphers on;

        # Add an HSTS header (Highly recommended for security)
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
        
        root         /usr/share/nginx/html  ;
        client_max_body_size 75M;

        # Load configuration files for the default server block.
        include /opt/app-root/etc/nginx.default.d/*.conf;

        location ~ /api3/(.*)$ {
           return 307 ${SSO_BACKEND_HOST}/api/${DOLLAR}1${DOLLAR}is_args${DOLLAR}args;
        }

        location /api1/ {
           proxy_pass http://${RAG_IP}:${RAG_PORT}/api/;
           proxy_set_header X-Real-IP ${DOLLAR}remote_addr;
           proxy_set_header X-Forwarded-For ${DOLLAR}proxy_add_x_forwarded_for;
           proxy_set_header X-Forwarded-Proto ${DOLLAR}scheme;
           proxy_cookie_path / /;

           # Using nginx default timeouts (60s) for regular API calls
        }

        # Long-running workflow execution endpoint - needs extended timeouts
        # This MUST come BEFORE the general /api2/ location block
        # Nginx matches locations in order: more specific first
        # Using regex to match exact endpoint, then rewrite to use same proxy_pass pattern
        location ~ ^/api2/sessions/user\.session\.execute$ {
           rewrite ^/api2/(.*)$ /api/$1 break;
           proxy_pass  http://${MULTIAGENT_IP}:${MULTIAGENT_PORT};
           proxy_set_header X-Real-IP ${DOLLAR}remote_addr;
           proxy_set_header X-Forwarded-For ${DOLLAR}proxy_add_x_forwarded_for;
           proxy_set_header X-Forwarded-Proto ${DOLLAR}scheme;
           proxy_cookie_path / /;

           # Extended timeout settings for long-running workflows (10 minutes)
           proxy_connect_timeout 600s;
           proxy_send_timeout 600s;       # 10 minutes - time to send request to upstream
           proxy_read_timeout 600s;       # 10 minutes - time to read response from upstream
           send_timeout 600s;             # 10 minutes - time to send response to client
           
           # Keep connection alive for long operations
           proxy_buffering off;           # Disable buffering for streaming responses
        }

        # General multi-agent API endpoints - using default timeouts to prevent hanging connections
        location /api2/ {
           proxy_pass  http://${MULTIAGENT_IP}:${MULTIAGENT_PORT}/api/;
           proxy_set_header X-Real-IP ${DOLLAR}remote_addr;
           proxy_set_header X-Forwarded-For ${DOLLAR}proxy_add_x_forwarded_for;
           proxy_set_header X-Forwarded-Proto ${DOLLAR}scheme;
           proxy_cookie_path / /;

           # Using nginx default timeouts (60s) for regular API calls
        }

        # Platform backend (admin config service)
        location /api4/ {
           proxy_pass http://${BACKEND_IP}:${BACKEND_PORT}/api/;
           proxy_set_header X-Real-IP ${DOLLAR}remote_addr;
           proxy_set_header X-Forwarded-For ${DOLLAR}proxy_add_x_forwarded_for;
           proxy_set_header X-Forwarded-Proto ${DOLLAR}scheme;
           proxy_set_header X-Username ${DOLLAR}http_x_username;
           proxy_set_header X-User-Id ${DOLLAR}http_x_user_id;
           proxy_cookie_path / /;
        }

        location / {
            index index.html;
            try_files ${DOLLAR}uri /index.html;
        }

        # For static assets (JS/CSS/images/fonts) → cache long term
        location ~* \.(?:ico|css|js|gif|jpe?g|png|woff2?|eot|ttf|svg)$ {
            root /usr/share/nginx/html;
            access_log off;
            add_header Cache-Control "public, max-age=31536000, immutable";
        }

        # For index.html → always fetch latest
        location = /index.html {
            root /usr/share/nginx/html;
            add_header Cache-Control "no-cache, no-store, must-revalidate";
        }

        location = /404.html {
        }

    }


}