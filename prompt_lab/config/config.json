{
  "storage_type": "file",
  "input": {
    "file_path": "${INPUT_JSON_PATH}"
  },
  "output": {
    "directory": "${OUTPUT_DATA_DIR_PATH}"
  },
  "model_config": {
    "tokenizer_path": "oodeh/mta-DeepCode-r32-a32-epoch20",
    "model_name": "oodeh/mta-DeepCode-r32-a32-epoch20",
    "api_url": "http://0.0.0.0:8000/v1/completions",
    "max_generation_length": 4096,
    "max_context_length": 16384
  },
  "prompt_lab": {
    "batch_size": 16,
    "queues": {
      "fetch_prompts_queue": {
        "target_size": 64,
        "name": "prompts_process_queue"
      }
    }
  },
  "reviewer": {
    "queues": {
      "reviewer_passed_queue": {
        "name": "reviewer_passed"
      }
    }
  },
  "rabbitmq": {
    "port": ${RABBITMQ_PORT},
    "url": "amqp://${RABBITMQ_IP}:{port}"
  },
  "mongodb": {
    "port": ${MONGODB_PORT},
    "url": "mongodb://${MONGODB_IP}:{port}"
  },
  "templates": {
    "project_path": "projects_templates/TAG/typescript.json",
    "usable_params": [
      "project_id",
      "project_repo",
      "coding_language"
    ]
  }
}
